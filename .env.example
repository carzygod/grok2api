GROK2API_DATA_DIR=/app/data
GROK2API_BROWSER_BASE_URL=http://127.0.0.1:18200
GROK2API_BROWSER_MODE=docker-novnc
GROK2API_BROWSER_IMAGE=grok2api-browser:latest
GROK2API_BROWSER_PORT_BASE=18200
GROK2API_BROWSER_DEBUG_PORT_BASE=19200
GROK2API_BROWSER_TIMEZONE=Asia/Taipei
GROK2API_BROWSER_PROXY_SERVER=
GROK2API_BROWSER_PROXY_BYPASS_LIST=
